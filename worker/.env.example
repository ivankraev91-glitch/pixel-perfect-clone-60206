# --- Lovable Cloud (Supabase) ---
# Возьми в Lovable: открой проект → Connectors → Lovable Cloud → URL и Service role key
SUPABASE_URL=https://rxpbgvfwgxxkiocvwjhp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...твой_service_role_ключ...

# --- ProxyLine (RU residential) ---
# Список прокси через запятую или с новой строки.
# Поддерживаемые форматы:
#   ip:port:user:pass
#   user:pass@ip:port
#   http://user:pass@ip:port
RU_PROXY_LIST=ip1:port:user:pass,ip2:port:user:pass

# --- RuCaptcha / 2Captcha ---
CAPTCHA_PROVIDER=rucaptcha
CAPTCHA_API_KEY=твой_api_key_rucaptcha

# --- Worker tuning ---
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=5
WORKER_MAX_ATTEMPTS=5

# --- Headless-browser fallback for Yandex Maps SERP ---
# Включается, только когда дешёвый fetch+regex путь вернул 0 карточек
# (Карты — SPA, иногда SSR-HTML приходит пустым). Требует playwright + chromium:
#   npx playwright install --with-deps chromium
WORKER_BROWSER_FALLBACK=false
